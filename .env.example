# --- Base de datos (Neon Postgres) ---
# Connection string "pooled" que te da Neon (para runtime)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Connection string "direct" (no pooled) que te da Neon (solo para migraciones)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Sesion admin ---
# Clave secreta larga y aleatoria para firmar la cookie de sesion. Generarla con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="reemplazar-por-una-clave-aleatoria-larga"

# Credenciales del unico usuario admin
ADMIN_EMAIL="automaticcdev@gmail.com"
# Hash bcrypt de la contraseña (nunca la contraseña en texto plano). Generarlo con:
# node -e "require('bcryptjs').hash(process.argv[1], 12).then(console.log)" "tu-contraseña"
ADMIN_PASSWORD_HASH="reemplazar-por-el-hash-bcrypt"

# --- Email (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CONTACT_TO_EMAIL="automaticcdev@gmail.com"

# --- Imagenes (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# --- Publicas (visibles en el navegador) ---
NEXT_PUBLIC_SITE_URL="https://automaticdev.cloud"
NEXT_PUBLIC_WHATSAPP_NUMBER="542236015295"
NEXT_PUBLIC_INSTAGRAM_HANDLE="automaticcdev"
